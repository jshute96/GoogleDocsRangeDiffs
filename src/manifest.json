{
  "manifest_version": 3,
  "name": "Google Docs Range Diffs",
  "version": "1.0.0",
  "description": "Adds diff-between-versions feature to Google Docs",
  "homepage_url": "https://github.com/jshute96/GoogleDocsRangeDiffs/blob/main/README.md",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content-revisions.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Google Docs Range Diffs",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
